{
  "Equation Array": {
    "prefix": "eqarr",
    "body": [
      "\\\\left\\\\{",
      "   \\\\begin{aligned}",
      "      $0",
      "   \\\\end{aligned}",
      "\\\\right."
    ],
    "description": "插入 LaTeX 方程组（大括号对齐）"
  },
  "Multiline Equation": {
    "prefix": "eqm",
    "body": [
      "\\$\\$",
      "\\\\begin{aligned}",
      "   $0",
      "\\\\end{aligned}",
      "\\$\\$"
    ],
    "description": "插入多行对齐公式块"
  },
  "Inline Equation": {
    "prefix": "eqi",
    "body": [
      "\\$ $1 \\$ $0"
    ],
    "description": "插入行内公式"
  },
  "Inline Equation with Displaystyle": {
    "prefix": "eqid",
    "body": [
      "\\$\\displaystyle $0\\$"
    ],
    "description": "插入行内强制大尺寸公式"
  },
  "Equation": {
    "prefix": "eq",
    "body": [
      "\\$\\$",
      "$0",
      "\\$\\$"
    ],
    "description": "插入标准居中公式"
  },
  "Summation": {
    "prefix": "sum",
    "body": [
      "\\\\sum_{$1}^{$2}$0"
    ],
    "description": "插入求和符号"
  },
  "Differential": {
    "prefix": "diff",
    "body": [
      "\\\\mathrm{d}$0"
    ],
    "description": "插入微分符号 d"
  },
  "Derivative": {
    "prefix": "deriv",
    "body": [
      "\\\\frac{\\\\mathrm{d}$1}{\\\\mathrm{d}$2}$0"
    ],
    "description": "插入全导数"
  },
  "Partial Derivative": {
    "prefix": "pderiv",
    "body": [
      "\\\\frac{\\\\partial $1}{\\\\partial $2}$0"
    ],
    "description": "插入偏导数"
  },
  "Define Integral": {
    "prefix": "dint",
    "body": [
      "\\\\int_{$1}^{$2} $3 \\\\, \\\\mathrm{d}$4"
    ],
    "description": "插入定积分"
  },
  "Integral": {
    "prefix": "int",
    "body": [
      "\\\\int $1 \\\\, \\\\mathrm{d}$2"
    ],
    "description": "插入不定积分"
  },
  "Fraction": {
    "prefix": "//",
    "body": [
      "\\\\frac{$1}{$2}$0"
    ],
    "description": "插入分式"
  },
  "Residue": {
    "prefix": "res",
    "body": [
      "\\\\operatorname{Res}\\\\left[$1, $2\\\\right]$0"
    ],
    "description": "插入留数符号"
  }
}
